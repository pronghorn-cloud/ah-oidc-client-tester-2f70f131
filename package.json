{
  "name": "oidc-testing-client",
  "version": "1.0.0",
  "description": "OIDC Testing Client for OAuth 2.0 and OpenID Connect flow testing",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install",
    "test": "npm run test:server && npm run test:client",
    "test:server": "jest --config server/jest.config.js",
    "test:client": "cd client && npm test"
  },
  "keywords": [
    "oidc",
    "oauth2",
    "openid-connect",
    "testing",
    "identity-provider"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jose": "^5.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
